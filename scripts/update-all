#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$script_dir/_workspace.sh"

update_repo() {
  local repo="$1"
  local target="$2"

  echo "== $repo =="
  if [ ! -f "$target/flake.nix" ]; then
    echo "missing flake.nix"
    return
  fi

  nix flake update --flake "$target"
}

for_each_repo update_repo
