#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$script_dir/_workspace.sh"

check_repo() {
  local repo="$1"
  local target="$2"

  echo "== $repo =="
  if [ ! -f "$target/flake.nix" ]; then
    echo "missing flake.nix"
    return
  fi

  nix flake check "$target" --no-build --option eval-cache false || true
}

for_each_repo check_repo
