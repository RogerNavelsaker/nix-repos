#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "$script_dir/_workspace.sh"

pull_repo() {
  local repo="$1"
  local target="$2"
  if [ ! -d "$target/.git" ]; then
    echo "== $repo =="
    echo "missing"
    return
  fi

  echo "== $repo =="
  git -C "$target" pull --rebase
}

for_each_repo pull_repo
